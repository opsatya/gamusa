{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**", "index.html", "vite.config.ts", "tsconfig.json"],
      "outputs": ["dist/**"],
      "env": [
        "VITE_API_BASE_URL",
        "VITE_DEV_COMPANY_SLUG",
        "VITE_MSG91_WIDGET_ID",
        "VITE_MSG91_TOKEN_AUTH"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "inputs": ["src/**", "tests/**"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
